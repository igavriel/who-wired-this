{
    "workbench.colorCustomizations": {
        "activityBar.activeBackground": "#80f0e6",
        "activityBar.background": "#80f0e6",
        "activityBar.foreground": "#15202b",
        "activityBar.inactiveForeground": "#15202b99",
        "activityBarBadge.background": "#dd54eb",
        "activityBarBadge.foreground": "#15202b",
        "commandCenter.border": "#15202b99",
        "sash.hoverBorder": "#80f0e6",
        "statusBar.background": "#52ebdd",
        "statusBar.foreground": "#15202b",
        "statusBarItem.hoverBackground": "#24e6d4",
        "statusBarItem.remoteBackground": "#52ebdd",
        "statusBarItem.remoteForeground": "#15202b",
        "titleBar.activeBackground": "#52ebdd",
        "titleBar.activeForeground": "#15202b",
        "titleBar.inactiveBackground": "#52ebdd99",
        "titleBar.inactiveForeground": "#15202b99"
    },
    "peacock.color": "#52ebdd",
    "omnisharp.useModernNet": true,
    "omnisharp.defaultLaunchSolution": "who-wired-this.sln",
    "omnisharp.enableRoslynAnalyzers": false,
    "omnisharp.enableDecompilationSupport": true,
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "files.watcherExclude": {
        "**/Library/**": true,
        "**/Temp/**": true,
        "**/Obj/**": true,
        "**/Logs/**": true,
        "**/.git/**": true
    },
    "files.exclude": {
        "**/.vs": true,
        "**/Obj": true
    },
    "search.exclude": {
        "**/Library": true,
        "**/Temp": true,
        "**/Obj": true,
        "**/Logs": true,
        "**/*.meta": true
    },
    "dotnet.defaultSolution": "who-wired-this.slnx"
}